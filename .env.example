# ---- Clinical Documentation Assistant — environment contract ----
# Copy to .env and fill in. NEVER commit .env. Synthetic data only (see §5).
# See docs/ARCHITECTURE.md for the trust boundary and where each var is read.

# --- Database (Phase 1) ---
DATABASE_URL=postgresql+psycopg://clin:clin@localhost:5432/clin_doc

# --- Auth (Phase 2) ---
JWT_SECRET=change-me-in-production
JWT_ALG=HS256
JWT_TTL_MINUTES=480

# --- Shared LLM API key ---
# S1 (clinical_core), S2 (phi), and S3 (auto_medical_coder) all read API_KEY.
# This is just "the key for whichever provider you set below" — it is passed
# straight through to LiteLLM, so it can be an Anthropic key, an OpenAI key, a
# Gemini key, etc. Leave unset (and no LLM_MODEL/MODEL override needed) for a
# local/self-hosted provider like Ollama that doesn't require a key.
API_KEY=

# --- S1 / clinical_core LLM (summarizer + B1 referral generation reuse this) ---
# clinical_core reads LLM_MODEL as a LiteLLM "<provider>/<model>" string — NOT
# locked to Claude/Anthropic. Any LiteLLM-supported provider works, e.g.:
#   anthropic/claude-opus-4-8   (default; needs API_KEY = an Anthropic key)
#   openai/gpt-5                (needs API_KEY = an OpenAI key)
#   gemini/gemini-2.5-pro       (needs API_KEY = a Gemini key)
#   ollama/llama3               (local; no API_KEY needed)
# See https://docs.litellm.ai/docs/providers for the full provider list.
LLM_MODEL=anthropic/claude-opus-4-8

# --- S3 auto-medical-coder LLM ---
# S3 reads MODEL — same "<provider>/<model>" LiteLLM string as LLM_MODEL above,
# also swappable to any supported provider (openai/gpt-5, gemini/..., ollama/...).
MODEL=anthropic/claude-sonnet-5

# --- S2 phi-deidentifier ---
# 'mask' (B1 default) needs no key. 'hash'/'surrogate' need PHI_HASH_KEY.
PHI_HASH_KEY=
PHI_REGIONS=NZ,AU

# --- M1 scribe (local Apple-Silicon dev path only) ---
# Cloud path uses faster-whisper per Phase 0 Decision B (docs/ARCHITECTURE.md).
SCRIBE_AUDIO_SOURCE=file

# --- Speaker diarization (sherpa-onnx, M1's phase1 extra) ---
# Both unset (default) = NullDiarizer, every speaker labeled UNKNOWN. Set both
# to real .onnx paths for CLINICIAN/PATIENT role labels. Use the same
# embedding model ai-ambient-scribe's own production config and PriMock57
# bake-off eval use (scribe/api/app.py _PROD_CFG, scripts/run_bakeoff_for_report.py)
# — NOT the 3dspeaker/campplus model from the README's generic example, which
# measurably fails to separate the two speakers on real consult audio (tested:
# ~93% of utterances collapsed into one speaker cluster). Fetch:
#   mkdir -p ../ai-ambient-scribe/data/.cache/sherpa-models && cd $_
#   curl -sSL -O https://github.com/k2-fsa/sherpa-onnx/releases/download/speaker-segmentation-models/sherpa-onnx-pyannote-segmentation-3-0.tar.bz2
#   tar xjf sherpa-onnx-pyannote-segmentation-3-0.tar.bz2 && rm sherpa-onnx-pyannote-segmentation-3-0.tar.bz2
#   curl -sSL -O https://github.com/k2-fsa/sherpa-onnx/releases/download/speaker-recongition-models/nemo_en_titanet_small.onnx
# Requires uv sync --extra local-mac (pulls ai-ambient-scribe[phase1]) and
# 16kHz mono PCM WAV input audio (sherpa-onnx does not resample).
DIARIZER_MODEL_PATH=../ai-ambient-scribe/data/.cache/sherpa-models/nemo_en_titanet_small.onnx
DIARIZER_SEGMENTATION_MODEL_PATH=../ai-ambient-scribe/data/.cache/sherpa-models/sherpa-onnx-pyannote-segmentation-3-0/model.onnx

# --- Deployment (Phase 5) ---
# ASR backend: mlx_whisper (local Apple-Silicon dev) | faster_whisper (cloud/demo).
ASR_BACKEND=mlx_whisper
# S3 baked artefacts (pinned to absolute paths in the Docker image; for bare
# local dev leave commented so S3 uses its relative ./data default).
#CATALOGUE_PATH=/app/data/icd10cm_catalogue.parquet
#CHROMA_DIR=/app/data/chroma
# Rate limiting for the public demo (off by default).
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=20
# Synthetic-data banner — always true in the demo (§11).
SYNTHETIC_DATA_ONLY=true
